# SmartLangGuard Environment Variables
# Copy this file to .env and fill in your values

# PostgreSQL (for production)
DATABASE_URL=postgresql://smartlangguard:your_secure_password@localhost:5432/smartlangguard
POSTGRES_PASSWORD=your_secure_password

# Redis (for caching)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# JWT (change in production!)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Admin credentials (for first-time setup)
ADMIN_DEFAULT_PASSWORD=your_secure_admin_password

# Offline secret for license tokens (change in production!)
SMARTLANGGUARD_OFFLINE_SECRET=your-super-secret-offline-key-change-in-production

# API endpoints
SMARTLANGGUARD_API=http://localhost:4000

# CORS
CORS_ORIGIN=http://localhost:3000

# Node environment
NODE_ENV=development
