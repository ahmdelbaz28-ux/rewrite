# =============================================================================
# SmartLangGuard - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# This file is used by the backend, daemon, and other packages.
# =============================================================================

# -----------------------------------------------------------------------------
# Core Settings (used by all packages)
# -----------------------------------------------------------------------------
# Endpoint for the SmartLangGuard SaaS API (used by CLI, Daemon, VS Code, etc.)
SMARTLANGGUARD_API=http://localhost:4000

# -----------------------------------------------------------------------------
# Backend Server Settings
# -----------------------------------------------------------------------------
# Port for the backend server
PORT=4000

# Allowed origins for CORS (comma-separated)
CORS_ORIGIN=*

# Path to the SQLite database file
SMARTLANGGUARD_DB_PATH=~/.smartlangguard/saas.db

# -----------------------------------------------------------------------------
# Admin Dashboard Settings
# -----------------------------------------------------------------------------
# Default admin username and password (seeded on first run)
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=admin123

# -----------------------------------------------------------------------------
# Stripe Settings (for subscription management)
# -----------------------------------------------------------------------------
# Stripe secret key (sk_test_... or sk_live_...)
STRIPE_SECRET_KEY=

# Stripe publishable key (pk_test_... or pk_live_...)
STRIPE_PUBLISHABLE_KEY=

# Stripe webhook secret (whsec_... from Stripe Dashboard)
STRIPE_WEBHOOK_SECRET=

# Stripe price IDs for each tier
STRIPE_PRICE_PRO=
STRIPE_PRICE_TEAM=
STRIPE_PRICE_ENTERPRISE=

# Frontend URL for Stripe redirects (e.g., https://app.smartlangguard.com)
FRONTEND_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Telemetry Settings
# -----------------------------------------------------------------------------
# Enable/disable telemetry (true/false)
TELEMETRY_ENABLED=true

# Telemetry endpoint (default: same as SMARTLANGGUARD_API)
TELEMETRY_ENDPOINT=

# -----------------------------------------------------------------------------
# License Settings
# -----------------------------------------------------------------------------
# License validation endpoint (default: same as SMARTLANGGUARD_API)
LICENSE_ENDPOINT=

# -----------------------------------------------------------------------------
# AI Scoring Settings
# -----------------------------------------------------------------------------
# Enable/disable AI scoring (true/false)
AI_SCORING_ENABLED=true

# Use remote AI scoring (true) or local custom model (false)
USE_REMOTE_AI_SCORING=false

# -----------------------------------------------------------------------------
# Daemon Settings
# -----------------------------------------------------------------------------
# Port for the daemon's local HTTP API (for browser extensions)
DAEMON_PORT=41783

# Enable/disable clipboard monitoring (true/false)
DAEMON_MONITOR_CLIPBOARD=true

# Enable/disable global hotkey (true/false)
DAEMON_ENABLE_HOTKEY=true

# Global hotkey for quick-fix (default: Ctrl+Shift+Space)
DAEMON_HOTKEY=Ctrl+Shift+Space

# -----------------------------------------------------------------------------
# Node.js Settings
# -----------------------------------------------------------------------------
# Node.js environment (development, test, production)
NODE_ENV=development

# =============================================================================
# Example for Production
# =============================================================================
# SMARTLANGGUARD_API=https://api.smartlangguard.com
# PORT=443
# CORS_ORIGIN=https://app.smartlangguard.com,https://smartlangguard.com
# ADMIN_DEFAULT_PASSWORD=your_secure_password_here
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# FRONTEND_URL=https://app.smartlangguard.com
# NODE_ENV=production
# =============================================================================
