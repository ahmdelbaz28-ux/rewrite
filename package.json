{
  "name": "smartlangguard",
  "version": "0.2.0",
  "private": true,
  "description": "SmartLangGuard - Cross-platform keyboard layout mistake fixer (CLI, MCP, Daemon, VS Code, SaaS)",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "bootstrap": "npm install",
    "build": "node scripts/build-all.js",
    "build:cli": "npm run build --workspace @smartlangguard/cli",
    "build:windows": "npm run build:windows --workspace @smartlangguard/cli",
    "build:macos": "npm run build:macos --workspace @smartlangguard/cli",
    "build:linux": "npm run build:linux --workspace @smartlangguard/cli",
    "build:vscode": "npm run compile --workspace smartlangguard",
    "start:backend": "npm start --workspace @smartlangguard/backend",
    "start:daemon": "npm start --workspace @smartlangguard/daemon",
    "start:mcp": "node packages/mcp-server/src/mcp-server.js",
    "test": "jest --config jest.config.json",
    "test:core": "jest --config jest.config.json --testPathPattern=\"packages/core/tests\"",
    "test:backend": "jest --config jest.config.json --testPathPattern=\"packages/backend/tests\"",
    "test:mcp": "jest --config jest.config.json --testPathPattern=\"packages/mcp-server/tests\"",
    "release": "node scripts/release.js",
    "clean": "node -e \"const fs=require('fs'),p=require('path');['packages'].forEach(d=>fs.readdirSync(d).forEach(s=>{const pp=p.join(d,s);['node_modules','dist','out'].forEach(n=>{const fp=p.join(pp,n);if(fs.existsSync(fp))fs.rmSync(fp,{recursive:true})})}))\""
  },
  "keywords": [
    "arabic",
    "keyboard",
    "layout",
    "auto-correct",
    "mcp",
    "cli",
    "saas"
  ],
  "author": "SmartLangGuard <hello@smartlangguard.com>",
  "license": "PROPRIETARY",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^5.16.1",
    "jest": "^29.7.0"
  }
}
