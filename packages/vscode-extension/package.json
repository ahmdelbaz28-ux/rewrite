{
  "name": "smartlangguard",
  "displayName": "SmartLangGuard",
  "description": "Fix Arabic/English keyboard layout mistakes instantly. Works in any text editor, terminal, or AI tool.",
  "version": "0.1.0",
  "publisher": "smartlangguard",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/ahmdelbaz28-ux/rewrite.git"
  },
  "homepage": "https://github.com/ahmdelbaz28-ux/rewrite#readme",
  "bugs": {
    "url": "https://github.com/ahmdelbaz28-ux/rewrite/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Productivity",
    "Language Packs"
  ],
  "keywords": [
    "arabic",
    "keyboard",
    "layout",
    "fix",
    "auto-correct",
    "typing",
    "mistype",
    "qwerty",
    "rtl",
    "middle-east"
  ],
  "icon": "assets/icon.png",
  "galleryBanner": {
    "color": "#1e293b",
    "theme": "dark"
  },
  "badges": [
    {
      "url": "https://img.shields.io/badge/version-0.1.0-blue.svg",
      "href": "https://github.com/ahmdelbaz28-ux/rewrite/releases",
      "description": "Version 0.1.0"
    },
    {
      "url": "https://img.shields.io/badge/platforms-Win%20%7C%20macOS%20%7C%20Linux-lightgrey.svg",
      "href": "https://github.com/ahmdelbaz28-ux/rewrite",
      "description": "Cross-platform"
    },
    {
      "url": "https://img.shields.io/badge/tests-306%20passing-brightgreen.svg",
      "href": "https://github.com/ahmdelbaz28-ux/rewrite/actions",
      "description": "306 tests passing"
    }
  ],
  "activationEvents": [
    "onCommand:smartlangguard.fixSelection",
    "onCommand:smartlangguard.fixClipboard",
    "onCommand:smartlangguard.fixLastWord",
    "onCommand:smartlangguard.activateLicense",
    "onCommand:smartlangguard.showStatus",
    "onCommand:smartlangguard.toggleRealTime",
    "onCommand:smartlangguard.testSound",
    "onCommand:smartlangguard.selectSound",
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "smartlangguard.fixSelection",
        "title": "SmartLangGuard: Fix Selection"
      },
      {
        "command": "smartlangguard.fixClipboard",
        "title": "SmartLangGuard: Fix Clipboard"
      },
      {
        "command": "smartlangguard.fixLastWord",
        "title": "SmartLangGuard: Fix Last Word (Quick Fix)"
      },
      {
        "command": "smartlangguard.activateLicense",
        "title": "SmartLangGuard: Activate License"
      },
      {
        "command": "smartlangguard.showStatus",
        "title": "SmartLangGuard: Show Status"
      },
      {
        "command": "smartlangguard.toggleRealTime",
        "title": "SmartLangGuard: Toggle Real-Time Detection"
      },
      {
        "command": "smartlangguard.testSound",
        "title": "SmartLangGuard: Test Alert Sound"
      },
      {
        "command": "smartlangguard.selectSound",
        "title": "SmartLangGuard: Select Alert Sound"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "smartlangguard.fixSelection",
          "when": "editorHasSelection",
          "group": "smartlangguard@1"
        },
        {
          "command": "smartlangguard.fixLastWord",
          "when": "!editorHasSelection",
          "group": "smartlangguard@2"
        }
      ],
      "commandPalette": [
        {
          "command": "smartlangguard.fixSelection",
          "when": "editorHasSelection"
        },
        {
          "command": "smartlangguard.fixLastWord"
        },
        {
          "command": "smartlangguard.toggleRealTime"
        },
        {
          "command": "smartlangguard.testSound"
        },
        {
          "command": "smartlangguard.selectSound"
        }
      ]
    },
    "keybindings": [
      {
        "command": "smartlangguard.fixSelection",
        "key": "ctrl+shift+f1",
        "mac": "cmd+shift+f1",
        "when": "editorHasSelection"
      },
      {
        "command": "smartlangguard.fixClipboard",
        "key": "ctrl+shift+f2",
        "mac": "cmd+shift+f2"
      },
      {
        "command": "smartlangguard.fixLastWord",
        "key": "ctrl+shift+backspace",
        "mac": "cmd+shift+backspace",
        "when": "editorTextFocus"
      },
      {
        "command": "smartlangguard.toggleRealTime",
        "key": "ctrl+shift+alt+l",
        "mac": "cmd+shift+alt+l"
      }
    ],
    "configuration": {
      "title": "SmartLangGuard",
      "properties": {
        "smartlangguard.cliPath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Path to SmartLangGuard CLI binary. Leave empty to auto-detect (npm global install, bundled, or PATH)."
        },
        "smartlangguard.direction": {
          "type": "string",
          "enum": ["auto", "en-to-ar", "ar-to-en"],
          "default": "auto",
          "enumDescriptions": [
            "Auto-detect from text content",
            "Force English → Arabic conversion",
            "Force Arabic → English conversion"
          ],
          "description": "Default conversion direction"
        },
        "smartlangguard.useAI": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Enable AI scoring for ambiguous cases. Uses the built-in custom model (free, offline) for Pro users."
        },
        "smartlangguard.telemetry": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Send anonymous usage telemetry to help improve SmartLangGuard. No personal data is collected."
        },
        "smartlangguard.endpoint": {
          "type": "string",
          "default": "https://api.smartlangguard.com",
          "description": "SaaS API endpoint for license validation."
        },
        "smartlangguard.realTimeDetection": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "**Real-time typing detection.** When enabled, SmartLangGuard analyzes your typing as you type and plays a sound alert when it detects wrong keyboard layout. Use `Ctrl+Shift+Backspace` to fix the last word instantly.",
          "scope": "window"
        },
        "smartlangguard.sound": {
          "type": "string",
          "enum": ["off", "beep", "ding", "chime", "soft-pop", "click", "double-beep"],
          "default": "ding",
          "enumDescriptions": [
            "No sound (silent mode)",
            "Short square-wave beep (~150ms) - attention-grabbing",
            "Soft sine-wave ding (~300ms) - pleasant, recommended",
            "Ascending 3-note chime (~500ms) - musical",
            "Very soft damped pop (~200ms) - least intrusive",
            "Short click (~80ms) - very subtle",
            "Double beep (~250ms) - more urgent"
          ],
          "markdownDescription": "Sound to play when wrong keyboard layout is detected. Use command `SmartLangGuard: Test Alert Sound` to preview.",
          "scope": "window"
        },
        "smartlangguard.soundVolume": {
          "type": "number",
          "default": 0.5,
          "minimum": 0,
          "maximum": 1,
          "markdownDescription": "Volume for alert sounds (0.0 to 1.0).",
          "scope": "window"
        },
        "smartlangguard.sensitivity": {
          "type": "string",
          "enum": ["low", "medium", "high"],
          "default": "medium",
          "enumDescriptions": [
            "Only alert after 5+ consecutive wrong-layout characters",
            "Alert after 3+ consecutive wrong-layout characters (default)",
            "Alert after 2+ consecutive wrong-layout characters"
          ],
          "markdownDescription": "Detection sensitivity. Higher = more alerts (may false-positive).",
          "scope": "window"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "echo 'Skipping prepublish - using pre-built out/'",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "node /home/z/my-project/scripts/build-vscode-extension.js",
    "publish": "node /home/z/my-project/scripts/build-vscode-extension.js && echo 'Run: vsce publish' ",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^3.0.0"
  }
}
