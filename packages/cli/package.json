{
  "name": "@smartlangguard/cli",
  "version": "0.1.4",
  "description": "SmartLangGuard CLI - Fix Arabic/English keyboard layout mistakes from terminal",
  "main": "bin/smartlangguard.js",
  "bin": {
    "smartlangguard": "bin/smartlangguard.js",
    "slg": "bin/smartlangguard.js"
  },
  "scripts": {
    "start": "node bin/smartlangguard.js",
    "build": "npx --yes @yao-pkg/pkg@5.16.1 . --targets node18-win-x64,node18-macos-x64,node18-linux-x64 --out-path dist/",
    "build:windows": "npx --yes @yao-pkg/pkg@5.16.1 . --targets node18-win-x64 --output dist/smartlangguard-win-x64.exe",
    "build:macos": "npx --yes @yao-pkg/pkg@5.16.1 . --targets node18-macos-x64 --output dist/smartlangguard-macos-x64",
    "build:linux": "npx --yes @yao-pkg/pkg@5.16.1 . --targets node18-linux-x64 --output dist/smartlangguard-linux-x64"
  },
  "pkg": {
    "scripts": [
      "bin/**/*.js",
      "src/**/*.js"
    ],
    "assets": [
      "node_modules/@smartlangguard/core/src/**/*.js"
    ],
    "targets": [
      "node18-win-x64",
      "node18-macos-x64",
      "node18-linux-x64"
    ],
    "outputPath": "dist"
  },
  "keywords": [
    "cli",
    "arabic",
    "keyboard",
    "layout",
    "fix",
    "terminal",
    "smartlangguard"
  ],
  "author": "SmartLangGuard <hello@smartlangguard.com>",
  "license": "PROPRIETARY",
  "private": false,
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "bin/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ahmdelbaz28-ux/rewrite.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/ahmdelbaz28-ux/rewrite/issues"
  },
  "homepage": "https://github.com/ahmdelbaz28-ux/rewrite#readme",
  "dependencies": {
    "@smartlangguard/core": "^0.1.0",
    "@smartlangguard/mcp-server": "^0.1.0",
    "@smartlangguard/daemon": "^0.1.0",
    "commander": "^11.1.0"
  }
}
