# =============================================================================
# SmartLangGuard Backend - Environment Variables
# =============================================================================
# Copy this file to .env in the backend directory and fill in the values.
# This file is loaded by the backend server (packages/backend/src/server.js).
# =============================================================================

# -----------------------------------------------------------------------------
# Server Settings
# -----------------------------------------------------------------------------
# Port for the backend server
PORT=4000

# Allowed origins for CORS (comma-separated)
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Path to the SQLite database file
SMARTLANGGUARD_DB_PATH=~/.smartlangguard/saas.db

# -----------------------------------------------------------------------------
# Admin Settings
# -----------------------------------------------------------------------------
# Default admin username (seeded on first run)
ADMIN_DEFAULT_USERNAME=admin

# Default admin password (seeded on first run)
# CHANGE THIS IN PRODUCTION!
ADMIN_DEFAULT_PASSWORD=admin123

# -----------------------------------------------------------------------------
# Stripe Settings (for subscription management)
# -----------------------------------------------------------------------------
# Stripe secret key (sk_test_... or sk_live_...)
# Required for subscription management (checkout, webhooks, etc.)
STRIPE_SECRET_KEY=

# Stripe publishable key (pk_test_... or pk_live_...)
# Required for frontend checkout forms
STRIPE_PUBLISHABLE_KEY=

# Stripe webhook secret (whsec_... from Stripe Dashboard)
# Required for handling subscription events (e.g., checkout.session.completed)
STRIPE_WEBHOOK_SECRET=

# Stripe price IDs for each tier
# Create these in the Stripe Dashboard under Products > Pricing
STRIPE_PRICE_PRO=
STRIPE_PRICE_TEAM=
STRIPE_PRICE_ENTERPRISE=

# Frontend URL for Stripe redirects (e.g., https://app.smartlangguard.com)
# Used for success/cancel redirects after checkout
FRONTEND_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# API Keys and Secrets
# -----------------------------------------------------------------------------
# JWT secret for signing API tokens (generate a random string)
JWT_SECRET=your_jwt_secret_here

# -----------------------------------------------------------------------------
# Telemetry Settings
# -----------------------------------------------------------------------------
# Enable/disable telemetry collection (true/false)
TELEMETRY_ENABLED=true

# -----------------------------------------------------------------------------
# License Settings
# -----------------------------------------------------------------------------
# License validation endpoint (default: http://localhost:4000)
LICENSE_ENDPOINT=

# -----------------------------------------------------------------------------
# AI Scoring Settings
# -----------------------------------------------------------------------------
# Enable/disable AI scoring for ambiguous cases (true/false)
AI_SCORING_ENABLED=true

# Use remote AI scoring (true) or local custom model (false)
# Local model is free and offline but less accurate
USE_REMOTE_AI_SCORING=false

# -----------------------------------------------------------------------------
# Node.js Settings
# -----------------------------------------------------------------------------
# Node.js environment (development, test, production)
NODE_ENV=development

# -----------------------------------------------------------------------------
# Database Settings
# -----------------------------------------------------------------------------
# SQLite database path (default: ~/.smartlangguard/saas.db)
# Can also use :memory: for in-memory database (not recommended for production)
# SMARTLANGGUARD_DB_PATH=:memory:

# =============================================================================
# Example for Production
# =============================================================================
# PORT=443
# CORS_ORIGIN=https://app.smartlangguard.com,https://smartlangguard.com
# ADMIN_DEFAULT_USERNAME=admin
# ADMIN_DEFAULT_PASSWORD=your_secure_password_here
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRICE_TEAM=price_...
# STRIPE_PRICE_ENTERPRISE=price_...
# FRONTEND_URL=https://app.smartlangguard.com
# JWT_SECRET=your_secure_jwt_secret_here
# NODE_ENV=production
# =============================================================================